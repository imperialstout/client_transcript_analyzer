# Copy to ./.env in the project root and fill in values
# Legacy fallback still works from ~/.config/client-transcript-analyzer/.env

# Note: GITHUB_TOKEN is only needed for the retired archive/analyze.py and
# archive/analyze_uc.py scripts (direct GitHub Models API). The active
# analyze_copilot.py pipeline authenticates via the GitHub Copilot CLI instead.
# GITHUB_TOKEN=ghp_...

# Required: path to the folder containing BU subfolders of .vtt files
TRANSCRIPTS_PATH=C:\Users\you\OneDrive\Client\Call Transcripts

# Optional: OneDrive/SharePoint-synced folder containing source MP4 recordings.
# When set, run.py scans here for unprocessed videos (instead of TRANSCRIPTS_PATH),
# copies each MP4 to STAGING_PATH one at a time, transcribes it, then deletes the
# local copy. VTTs are written to TRANSCRIPTS_PATH mirroring the subfolder structure.
# RECORDINGS_PATH=C:\Users\you\Siemens AG\SX3SCPQ... - Recordings

# Optional: local staging folder for one-at-a-time MP4 downloads (default: ./staging).
# Needs ~1 GB free. Deleted automatically after each transcription.
# STAGING_PATH=C:\tmp\transcript_staging

# Optional: where to write [ANALYZED].txt and [BU SUMMARY].md files (defaults to ./output)
# OUTPUT_PATH=C:\Users\you\OneDrive\Client\Analyzed

# Optional: model overrides
# MODEL_TRANSCRIPT=claude-3-5-haiku-20241022   # low-tier, high rate limit
# MODEL_SUMMARY=claude-3-5-sonnet-20241022     # high-tier, lower rate limit

# Optional: seconds between API calls (increase if hitting 429s)
# RATE_LIMIT_SLEEP=2

# Optional: max seconds to wait for a single Copilot CLI call before giving up
# on that transcript and moving on (logged to NEEDS_FOLLOWUP.txt in OUTPUT_PATH).
# Defaults to 900 (15 min). Raise this if large transcripts routinely take longer.
# COPILOT_TIMEOUT_SECONDS=900
