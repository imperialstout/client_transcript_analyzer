# Copy to ./.env in the project root and fill in values
# Legacy fallback still works from ~/.config/client-transcript-analyzer/.env

# Required: GitHub PAT with models:read scope
GITHUB_TOKEN=ghp_...

# Required: path to the folder containing BU subfolders of .vtt files
TRANSCRIPTS_PATH=C:\Users\you\OneDrive\Client\Call Transcripts

# Optional: where to write [ANALYZED].txt and [BU SUMMARY].md files (defaults to ./output)
# OUTPUT_PATH=C:\Users\you\OneDrive\Client\Analyzed

# Optional: model overrides
# MODEL_TRANSCRIPT=claude-3-5-haiku-20241022   # low-tier, high rate limit
# MODEL_SUMMARY=claude-3-5-sonnet-20241022     # high-tier, lower rate limit

# Optional: seconds between API calls (increase if hitting 429s)
# RATE_LIMIT_SLEEP=2
